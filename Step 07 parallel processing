            .collect(Collectors.toConcurrentMap(
                Record::getId,
                record -> pathExists(record.getXmlString(), xpathExpression)
            ));
    }

    private static boolean pathExists(String xml, String xpathExpression) {
        try {
            XPath xpath = XPATH_THREAD_LOCAL.get();
            InputSource source = new InputSource(new StringReader(xml));
            String result = xpath.evaluate(xpathExpression, source);
            return result != null && !result.isEmpty();
        } catch (XPathExpressionException e) {
            return false; // treat malformed XML/path as false
        }
    }

