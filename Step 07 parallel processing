    public static void main(String[] args) {
        List<Record> records = List.of(
            new Record("id-001", "<root><orders><order>A</order></orders></root>"),
            new Record("id-002", "<root><orders></orders></root>"),
            new Record("id-003", "<root><other>data</other></root>")
        );

